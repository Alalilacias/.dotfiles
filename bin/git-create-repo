#!/usr/bin/env bash
# Author: Alalilacias
# Description: Automates local Git repo creation, initial commit, and pushing to GitHub.
# Version: 0.0.1

set -euo pipefail
IFS=$'\n\t'

readonly VERSION="0.0.1"
readonly SCRIPT_NAME="$(basename "$0")"
REPONAME=""
DESC=""
PRIV=true # true = private, false = public
LANGS="java"
LICENSE="mit"

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME [options]

Options:
  -h, --help              Show this help message
  -v, --version           Show version information
  -n, --name              Repository name (required)
  -d, --description       Repository description (optional)
  -p, --public            Create a public repository (default: private)
  -t, --technologies      Comma-separated list of technologies for .gitignore (default: java)
  -l, --license           License type (default: mit)
EOF
}
version() {
  echo "$SCRIPT_NAME version $VERSION"
}
parse_args() {
  # Parse options with getopt. As a quick reminder:
  #   Format: -o for short options, --long for long options
  #   Colon (:) after option means it requires an argument
  TEMP=$(getopt -o hvn:d:pt:l: --long help,version,name:,description:,public,technologies:,license: -n "$SCRIPT_NAME" -- "$@")

  if [ $? -ne 0 ]; then
    echo "Error: Failed to parse options" >&2
    usage
    exit 1
  fi

  eval set -- "$TEMP"

  while true; do
    case $1 in
    -h | --help)
      usage
      exit 0
      ;;
    -v | --version)
      version
      exit 0
      ;;
    -n | --name)
      REPONAME="$2"
      shift 2
      ;;
    -d | --description)
      DESC="$2"
      shift 2
      ;;
    -p | --public)
      PRIV=false
      shift
      ;;
    -t | --technologies)
      LANGS="$2"
      shift 2
      ;;
    -l | --license)
      LICENSE="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    esac
  done

  # Ensure REPONAME is set
  if [[ -z "$REPONAME" ]]; then
    echo "Repository name is required (-n or --name)"
    usage
    exit 1
  fi
}

check_dependencies() {
  command -v gh >/dev/null || {
    echo "gh CLI not installed"
    exit 1
  }
  command -v git >/dev/null || {
    echo "git not installed"
    exit 1
  }
  command -v add-gitignore >/dev/null || {
    echo "add-gitignore helper script not found in PATH"
    exit 1
  }
  command -v add-license >/dev/null || {
    echo "add-license helper script not found in PATH"
    exit 1
  }
}

check_correct_wd() {
  echo "You are about to create the repository '$1' at: $PWD"
  read -r -p "Continue? [y/N] " response
  response="${response,,}" # convert to lowercase

  if [[ "$response" != "y" && "$response" != "yes" ]]; then
    echo "Aborted by user."
    exit 1
  fi
}

check_repo_name() {
  if [[ -d "$1" ]]; then
    echo "Directory '$1' already exists."
    exit 1
  fi
}

main() {
  parse_args "$@"

  check_dependencies
  check_correct_wd "$REPONAME"
  check_repo_name "$REPONAME"

  mkdir "$REPONAME"

  add-gitignore -t "$REPONAME" -l "$LANGS"
  add-license -t "$REPONAME" -l "$LICENSE"

  cd "$REPONAME"

  # Init local repo
  git init -b main
  echo "# $REPONAME" >README.md
  git add .
  git commit -m "chore: initial commit"

  # Create GitHub repo via API (requires gh CLI)
  gh repo create "$REPONAME" \
    --description "$DESC" \
    --"$([[ "$PRIV" == "true" ]] && echo "private" || echo "public")" \
    --source=. \
    --remote=origin \
    --push
}

main "$@"
