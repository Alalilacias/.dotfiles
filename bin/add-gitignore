#!/usr/bin/env bash
#
# Author: Alalilacias
# Description: Automatically generates .gitignore file based on the opts provided
# Created at: 2026-03-15 20:21

set -euo pipefail
IFS=$'\n\t'

readonly VERSION="0.0.1"
readonly SCRIPT_NAME="$(basename "$0")"
readonly GITIGNORE_PATH=".dotfiles/share/gitignores/"
readonly GITIGNORE_DIR="$HOME/$GITIGNORE_PATH"
TARGET_DIR=''
LANGUAGES=()

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME [options]

Options:
  -h, --help      Show this help message
  -v, --version   Show version information
  -t, --target    Target directory for .gitignore (default: current directory)
  -l, --language  Specify language(s) (comma-separated or multiple flags)
EOF
}

version() {
  echo "$SCRIPT_NAME version $VERSION"
}

parse_args() {
  # Parse options with getopt. As a quick reminder:
  #   Format: -o for short options, --long for long options
  #   Colon (:) after option means it requires an argument
  TEMP=$(getopt -o hvt:l: --long help,version,target:,language: -n "$SCRIPT_NAME" -- "$@")

  if [ $? -ne 0 ]; then
    echo "Error: Failed to parse options" >&2
    usage
    exit 1
  fi

  eval set -- "$TEMP"

  while true; do
    case $1 in
    -h | --help)
      usage
      exit 0
      ;;
    -v | --version)
      version
      exit 0
      ;;
    -t | --target)
      TARGET_DIR="$2"
      shift 2
      ;;
    -l | --language)
      IFS=',' read -ra LANG_ARRAY <<<"$2"
      LANGUAGES=("${LANG_ARRAY[@]}")
      shift 2
      ;;
    --)
      shift
      break
      ;;
    esac
  done
}

validate_languages() {
  local requested_langs=("$@")
  local available_langs=()
  local valid_langs=()

  # Extract available gitignores
  if [[ -d "$GITIGNORE_DIR" ]]; then
    for file in "$GITIGNORE_DIR"/*; do
      if [[ -f "$file" ]]; then
        available_langs+=("$(basename "$file")")
      fi
    done
  fi

  # Check each requested language
  for requested in "${requested_langs[@]}"; do
    local found=0
    for available in "${available_langs[@]}"; do
      if [[ "$requested" == "$available" ]]; then
        found=1
        valid_langs+=("$requested")
        break
      fi
    done

    if [[ $found -eq 0 ]]; then
      echo ".gitignore file for language ${requested} not available"
    fi
  done

  LANGUAGES=("${valid_langs[@]}")

  return 0
}

validate_folders() {
  if [[ -z "$TARGET_DIR" ]]; then
    TARGET_DIR="$PWD"
    echo "No target directory specified, using current directory: $TARGET_DIR"
  else
    echo "Using specified target directory: $TARGET_DIR"
  fi

  # Check if gitignores directory exists
  if [[ ! -d "$GITIGNORE_DIR" ]]; then
    echo "Gitignores directory not found: $GITIGNORE_DIR" >&2
    echo "Please create it or check the path" >&2
    return 1
  fi

  # Check if target directory is writable
  if [[ ! -w "$TARGET_DIR" ]]; then
    echo "Error: Target directory is not writable: $TARGET_DIR" >&2
    return 1
  fi

  # Check if .gitignore already exists and warn
  if [[ -f "$TARGET_DIR/.gitignore" ]]; then
    echo "Warning: .gitignore already exists in $TARGET_DIR" >&2
    echo "It will be overwritten!" >&2

    read -p "Continue? (y/N) " -n 1 -r user_reply
    echo
    if [[ ! $user_reply =~ ^[Yy]$ ]]; then
      return 1
    fi
  fi

  return 0
}

extract_gitignores() {
  local target_file="$TARGET_DIR/.gitignore"
  local valid_langs=("${LANGUAGES[@]}")

  if [[ ${#valid_langs[@]} -eq 0 ]]; then
    echo "No valid languages to process. Skipping gitignore generation." >&2
    return 1
  fi

  echo "Generating .gitignore for: ${valid_langs[*]}"

  cat >"$target_file" <<EOF
# ..............................................................................
# .gitignore - Auto-generated by $SCRIPT_NAME
# Generated on: $(date)
# ..............................................................................
#
# This file was automatically generated by $SCRIPT_NAME v$VERSION
# Manual changes may be overwritten if the script is re-run.
#
# Languages included: ${valid_langs[*]}
#
# ..............................................................................

EOF

  for lang in "${valid_langs[@]}"; do
    local template_path="$GITIGNORE_PATH$lang"
    local template_file="$GITIGNORE_DIR/$lang"

    if [[ -f "$template_file" ]]; then
      cat >>"$target_file" <<EOF

# ------------------------------------------------------------------------------
# ${lang^^} - Gitignore rules for $lang
# Source: $template_path
# ------------------------------------------------------------------------------

EOF
      cat "$template_file" >>"$target_file"

      echo >>"$target_file"

      echo "Added $lang template"
    else
      echo "Template for $lang not found at $template_file" >&2
    fi
  done

  cat >>"$target_file" <<EOF

# ..............................................................................
#                           End of auto-generated .gitignore
# ..............................................................................
EOF

  echo "Successfully created .gitignore at $target_file"
  return 0
}

main() {
  local exit_code=0

  parse_args "$@"
  validate_folders
  exit_code=$?

  if [[ $exit_code -eq 0 ]]; then
    validate_languages "${LANGUAGES[@]}"
    extract_gitignores
  fi

  return $exit_code
}

main "$@"
